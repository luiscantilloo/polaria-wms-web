# URL del backend (polaria-wms-api).
# Producción (Render):
NEXT_PUBLIC_API_BASE_URL=https://polaria-wms-api.onrender.com

# Desarrollo local: descomenta la línea de abajo y comenta la de Render.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# URL del chatbot Mateo IA (SSO handoff).
NEXT_PUBLIC_MATEO_URL=https://chatbot-mateo.vercel.app

# Supabase (lecturas directas con RLS desde el navegador).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Integración n8n — pedido a proveedor (solo servidor; no usar NEXT_PUBLIC_).
# URL del webhook de n8n que genera/envía el documento al proveedor.
PEDIDO_PROVEEDOR_WEBHOOK_URL=https://your-n8n-instance.example/webhook/pedido-proveedor
# Identificador del documento/plantilla usado por el flujo n8n.
PEDIDO_PROVEEDOR_DOCUMENT_ID=your-document-or-template-id
